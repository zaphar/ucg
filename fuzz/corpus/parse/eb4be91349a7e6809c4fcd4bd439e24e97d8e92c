// fail expression in various contexts.
// We can only test the non-triggered path since triggering fail aborts.

// fail in a function via select (not triggered)
let validate = func(x) => select (x > 0, NULL) => {
    true = x,
    false = fail "must be positive",
};
assert {
    ok = validate(5) == 5,
    desc = "fail not triggered for valid positive input",
};
asseelect (not triggered)
let