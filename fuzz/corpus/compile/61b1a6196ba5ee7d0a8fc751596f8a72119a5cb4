// TRACE expression returns the value it wraps while printing debug output.

let x = TRACE 42;
assert {
    ok = x == 42,
    desc = "TRACE returns integer value",
};

let t = TRACE {a = 1, b = "hello"};
assert {
    ok = t.a == 1,
    desc = "TRACE returns tuple with accessible fields",
};
assert {
    ok = t.b == "hello",
    desc = "TRACE tuple stret s = TRACE "debug me";
assert {
    ok = s == "debug me",
    desc = "TRACE returns string value",
};
