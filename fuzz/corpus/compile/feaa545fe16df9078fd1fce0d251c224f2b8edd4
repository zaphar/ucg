// Shapes and their specifiers

let mystr::"" = "a string";

let struct_shape = {
    foo :: "" = "",
};

let func_shape = func(arg :: "", arg2 :: "") => arg + arg2;

let module_shape = module{self={}} => (result :: {}) {
    let result :: {} = self;
};

// Constraint enforcement: valid values accepted

assert t.ok{
    test = mystr == "a string",
    desc = "String constraint accepts valid string",
};

assert t.ok{
    test = struct_shape.foo == "",
    desc = "Tuple field with string constraint accepts valid value",
};

assert t.ok{
    test = func_shape("hello", " world") == "hello world",
    desc = "Func with constrained args works with valid types",
};

let myint :: 0 = 42;
assert t.ok{
    test = myint == 42,
    desc = "Int constraint accepts valid int value",
};

